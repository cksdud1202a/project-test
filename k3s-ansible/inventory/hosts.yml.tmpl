all:
  children:
    k3s_cluster:
      children:
        servers:
          hosts:
            kube-controller:
              ansible_host: ${SERVER_IP}
              ansible_user: ubuntu
              ansible_ssh_private_key_file: ~/.ssh/id_rsa
              ansible_ssh_common_args: '-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ForwardAgent=yes'
        
        agents:
          hosts:
            kube-node-1:
              ansible_host: ${AGENT1_IP}
              ansible_user: ubuntu
              ansible_ssh_private_key_file: ~/.ssh/id_rsa
            kube-node-2:
              ansible_host: ${AGENT2_IP}
              ansible_user: ubuntu
              ansible_ssh_private_key_file: ~/.ssh/id_rsa
          vars:
            ansible_ssh_common_args: >-
              -o ProxyCommand="ssh -A -W %h:%p -q ubuntu@${SERVER_IP} -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"
              -o ServerAliveInterval=60
              -o ServerAliveCountMax=3
              -o ConnectTimeout=30